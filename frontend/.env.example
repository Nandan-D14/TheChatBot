# Frontend Environment Variables Template
# Copy this file to .env.local and update the values for your environment.

# The URL of your Cloudflare Workers backend API
# Local development: http://localhost:8787
# Production: https://thechatbot-api.<your-account>.workers.dev
NEXT_PUBLIC_API_URL=http://localhost:8787

# The expected access key for authenticating with the backend
# This should match the APP_ACCESS_KEY set in your backend's wrangler.toml
NEXT_PUBLIC_APP_ACCESS_KEY=PES2UG23CS363
